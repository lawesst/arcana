{
  "name": "arcana",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time and historical analytics dashboard for Stylus dApps on Arbitrum",
  "scripts": {
    "dev:collector": "pnpm --filter @arcana/collector dev",
    "dev:api": "pnpm --filter @arcana/api dev",
    "dev:dashboard": "WATCHPACK_POLLING=true pnpm --filter @arcana/dashboard dev",
    "dev": "concurrently \"pnpm dev:collector\" \"pnpm dev:api\" \"pnpm dev:dashboard\"",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @arcana/db generate",
    "db:migrate": "pnpm --filter @arcana/db migrate",
    "staging:up": "docker compose --env-file .env.staging -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose --env-file .env.staging -f docker-compose.staging.yml down",
    "staging:logs": "docker compose --env-file .env.staging -f docker-compose.staging.yml logs -f",
    "staging:ps": "docker compose --env-file .env.staging -f docker-compose.staging.yml ps",
    "test:e2e:seed": "pnpm db:migrate && pnpm --filter @arcana/db seed:e2e",
    "test:e2e": "node scripts/reset-e2e-ports.mjs && rm -rf packages/dashboard/.next packages/dashboard/.next.broken.* && pnpm test:e2e:seed && pnpm build && playwright test",
    "test:e2e:headed": "node scripts/reset-e2e-ports.mjs && rm -rf packages/dashboard/.next packages/dashboard/.next.broken.* && pnpm test:e2e:seed && pnpm build && playwright test --headed",
    "test": "pnpm test:e2e",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
