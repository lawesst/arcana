# Public Arbitrum RPC for the collector
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_CHAIN_ID=42161

# Internal service connectivity inside docker-compose
DATABASE_URL=postgresql://arcana:arcana_dev@postgres:5432/arcana
REDIS_URL=redis://redis:6379

# Postgres bootstrap credentials
POSTGRES_USER=arcana
POSTGRES_PASSWORD=arcana_dev
POSTGRES_DB=arcana

# Internal service binding inside the containers
API_HOST=0.0.0.0
API_PORT=3001

# Public service ports on the staging host
DASHBOARD_PORT=3000
API_PUBLIC_PORT=3001

# Public URLs used by the browser
# Replace localhost with your staging domain or public host before deploying remotely.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Collector tuning
COLLECTOR_POLL_INTERVAL_MS=1000
COLLECTOR_BATCH_SIZE=100
